# Copy this file to .env and fill in your key to enable the AI agent.
# Without a key the app still runs in demo mode (data-only recommendations).
ANTHROPIC_API_KEY=sk-ant-...

# Optional
PORT=3000

# Optional: Socrata app token for higher Open Data NS rate limits during the
# daily data refresh. Get one free at https://data.novascotia.ca (sign in →
# create an app token). Not required — the pipeline works without it.
SOCRATA_APP_TOKEN=

# Optional: email itineraries to logged-in users via Gmail SMTP.
# 1) Turn on 2-Step Verification on your Google account.
# 2) Create an App Password: https://myaccount.google.com/apppasswords
# 3) Put your Gmail address + the 16-char app password below (NOT your login password).
# Leave blank to disable email — the app works fine without it.
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Optional: public URL used for links inside emails (defaults to http://localhost:PORT).
PUBLIC_BASE_URL=

# Optional: secret for signing login sessions. Set a long random string in
# production so sessions survive restarts/redeploys. Auto-generated locally if unset.
SESSION_SECRET=
